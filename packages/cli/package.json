{
  "name": "@imlogram/cli",
  "version": "0.1.2",
  "description": "Scan a project for old<->new Uzbek alphabet text, review it in a local browser UI, and apply approved changes straight to your source files.",
  "keywords": [
    "uzbek",
    "o'zbek",
    "latin",
    "alphabet",
    "cli",
    "codemod",
    "migration",
    "i18n"
  ],
  "homepage": "https://imlogram.uz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imlogram/imlogram.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/imlogram/imlogram/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "imlogram": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@imlogram/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
