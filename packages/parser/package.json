{
  "name": "@imlogram/parser",
  "version": "0.1.2",
  "description": "Segmentation and tokenization engine that protects code/URL/HTML/JSON regions from Uzbek Latin alphabet conversion.",
  "keywords": [
    "uzbek",
    "o'zbek",
    "latin",
    "alphabet",
    "parser",
    "tokenizer",
    "segmentation",
    "text-processing",
    "i18n",
    "uzbekistan"
  ],
  "homepage": "https://imlogram.uz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imlogram/imlogram.git",
    "directory": "packages/parser"
  },
  "bugs": "https://github.com/imlogram/imlogram/issues",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder)\""
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
