{
  "name": "@imlogram/core",
  "version": "0.1.1",
  "description": "Convert, detect, and analyze text between the old and new Uzbek Latin alphabets — code, URL, and markup safe.",
  "keywords": [
    "uzbek",
    "o'zbek",
    "uzbekcha",
    "latin",
    "cyrillic",
    "kirill",
    "alphabet",
    "alifbo",
    "transliteration",
    "converter",
    "text-processing",
    "i18n",
    "uzbekistan"
  ],
  "homepage": "https://imlogram.uz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imlogram/imlogram.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/imlogram/imlogram/issues",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint placeholder)\""
  },
  "dependencies": {
    "@imlogram/parser": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
